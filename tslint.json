
{
  "rulesDirectory": ["tslint-consistent-codestyle",  "tslint-eslint-rules", "node_modules/tslint-microsoft-contrib"],
  "rules": {
    "array-type": [
      true,
      "generic"
    ],
    "arrow-parens": true,
    "arrow-return-shorthand": true,
    "class-name": true,
    "curly": true,
    "eofline": true,
    "indent": [
      true,
      "spaces"
    ],
    "no-any": false,
    "no-duplicate-variable": true,
    "no-inferrable-types": true,
    "no-require-imports": true,
    "no-shadowed-variable": true,
    "no-trailing-whitespace": true,
    "no-typeof-undefined": true,
    "no-var-keyword": true,
    "no-var-requires": true,
    "no-unnecessary-semicolons": true,
    "no-unused-expression": false,
    "member-ordering": [
      true,
      {
        "order": [
          "public-static-method",
          "public-static-field",
          "public-instance-field",
          "protected-instance-field",
          "private-instance-field",
          "public-constructor",
          "protected-constructor",
          "private-constructor",
          "public-instance-method",
          "protected-instance-method",
          "private-instance-method",
          "protected-static-field",
          "private-static-field",
          "protected-static-method",
          "private-static-method"
        ]
      }
    ],
    "one-line": [
      true,
      "check-catch",
      "check-else",
      "check-finally",
      "check-open-brace",
      "check-whitespace"
    ],
    "only-arrow-functions": [
      true,
      "allow-named-functions"
    ],
    "prefer-const": true,
    "promise-must-complete": false,
    "quotemark": [
      true,
      "single",
      "avoid-escape"
    ],
    "semicolon": [
      true,
      "always",
      "ignore-bound-class-methods"
    ],
    "switch-default": true,
    "trailing-comma": [
      true,
      {
        "multiline": "never",
        "singleline": "never"
      }
    ],
    "triple-equals": true,
    "typedef": [
      true,
      "call-signature"
    ],
    "typedef-whitespace": [
      true,
      {
        "call-signature": "nospace",
        "index-signature": "nospace",
        "parameter": "nospace",
        "property-declaration": "nospace",
        "variable-declaration": "nospace"
      },
      {
        "call-signature": "onespace",
        "index-signature": "onespace",
        "parameter": "onespace",
        "property-declaration": "onespace",
        "variable-declaration": "onespace"
      }
    ],
    "variable-name": [
      true,
      "check-format",
      "allow-leading-underscore",
      "ban-keywords"
    ],
    "insecure-random": false,
    "no-banned-terms": true,
    "no-cookies": true,
    "no-delete-expression": true,
    "no-disable-auto-sanitization": true,
    "no-document-domain": true,
    "no-document-write": true,
    "no-eval": true,
    "no-exec-script": true,
    "no-function-constructor-with-string-args": true,
    "no-http-string": [
      true,
      "http://www.example.com/?.*",
      "http://www.examples.com/?.*"
    ],
    "no-octal-literal": true,
    "no-reserved-keywords": false,
    "no-string-based-set-immediate": true,
    "no-string-based-set-interval": true,
    "no-string-based-set-timeout": true,
    "non-literal-require": true,
    "possible-timing-attack": true,
    "missing-optional-annotation": false,
    "no-duplicate-parameter-names": false,
    "no-empty-interfaces": false,
    "no-missing-visibility-modifiers": false,
    "no-multiple-var-decl": false,
    "no-switch-case-fall-through": false
  }
}
