{
  "automock": false,
  "verbose": false,
  "silent": false,
  "testEnvironment": "node",
  "roots": [
    "<rootDir>/lib",
    "<rootDir>/test"
  ],
  "testRegex": ".+\\-spec\\.ts$",
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "moduleFileExtensions": [
    "ts",
    "js",
    "json"
  ],
  "collectCoverage": true,
  "coverageThreshold": {
    "global": {
      "statements": 100,
      "branches": 98,
      "lines": 100,
      "functions": 100
    }
  },
  "cacheDirectory": "<rootDir>/.jest",
  "collectCoverageFrom": [
    "lib/**/*.ts",
    "!test/utils.ts",
    "!**/node_modules/**"
  ]
}
