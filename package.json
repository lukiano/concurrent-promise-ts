{
  "name": "concurrent-promise-ts",
  "version": "0.0.5",
  "description": "An efficient promise executor",
  "author": "Luciano Leggieri",
  "license": "BSD-3-Clause",
  "keywords": [
    "promise",
    "typescript",
    "concurrency"
  ],
  "bugs": {
    "url": "https://bitbucket.org/lleggieri/concurrent-promise-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@bitbucket.org:lleggieri/concurrent-promise-ts.git"
  },
  "scripts": {
    "compile": "tsc",
    "build": "npm run verify-formatted && npm run lint && npm run compile",
    "format": "tsfmt -r",
    "lint": "tslint --project './tsconfig.json' -c tslint.json",
    "verify-formatted": "tsfmt --verify",
    "pretest": "npm run build",
    "test-only": "mocha --require ts-node/register `find ./test -name '*-spec.ts' -print`",
    "test-js": "mocha `find ./out -name '*-spec.js' -print`",
    "test": "npm run test-only",
    "precoverage": "npm run build",
    "coverage": "node node_modules/istanbul/lib/cli.js cover -e .js -x '*-spec.js' _mocha -- `find ./out -name '*-spec.js' -print`",
    "coveralls": "cat ./coverage/lcov.info | node node_modules/.bin/coveralls"
  },
  "devDependencies": {
    "@types/chai": "^4.1.7",
    "@types/chai-as-promised": "^7.1.0",
    "@types/mocha": "^5.2.5",
    "@types/node": "^10.12.10",
    "chai": "^4.2.0",
    "chai-as-promised": "^7.1.1",
    "coveralls": "^3.0.2",
    "istanbul": "1.1.0-alpha.1",
    "mocha": "^5.2.0",
    "ts-node": "^7.0.1",
    "tslint": "^5.11.0",
    "tslint-consistent-codestyle": "^1.14.1",
    "tslint-eslint-rules": "^5.4.0",
    "tslint-microsoft-contrib": "^5.2.1",
    "typescript": "^3.1.6",
    "typescript-formatter": "^7.2.2"
  },
  "main": "out/lib/index.js",
  "typings": "./out/lib/index.d.ts"
}
